# Google Sheets API integration
# The ID of the spreadsheet to fetch data from. (Find it in the URL: https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit)
SPREADSHEET_ID=your_spreadsheet_id_here

# Option 1: Use API Key (for reading from public spreadsheets)
GOOGLE_SHEETS_API_KEY=your_api_key_here

# Option 2: Use Service Account credentials (for reading/writing private spreadsheets)
# Compact the service account JSON into a single string
GOOGLE_SERVICE_ACCOUNT_CREDENTIALS={"type":"service_account","project_id":"..."}

# Server port for local development
PORT=3001
